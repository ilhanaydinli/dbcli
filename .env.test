# ============================================
# DB CLI - Test Environment Configuration
# ============================================
# This file is used for integration tests.
# Same values are used in CI/CD pipeline.
# ============================================

# ──────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=testdb

# ──────────────────────────────────────────
# MongoDB
# ──────────────────────────────────────────
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=
MONGO_PASSWORD=
MONGO_DB=admin

# ──────────────────────────────────────────
# MySQL / MariaDB
# ──────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=mysql
MYSQL_DB=testdb
